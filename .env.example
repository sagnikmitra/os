# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Optional: Google Gemini API (for alias generation in My Resumes)
VITE_GEMINI_API_KEY=your_gemini_api_key

# Note: Backend environment variables (GEMINI_API_KEY, FIRECRAWL_API_KEY, LOVABLE_API_KEY, 
# SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY) should be configured in Supabase dashboard
# under Project Settings → Edge Functions → Environment Variables, not in Vercel.
